---
import BaseLayout from "./BaseLayout.astro";
import type { CollectionEntry } from "astro:content";

export interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const { title, date, excerpt, author, categories, tags } = post.data;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

function slugify(s: string): string {
  return s.toLowerCase().replace(/\s+/g, "-");
}
---

<BaseLayout
  seo={{
    title,
    description: excerpt,
    canonicalURL: new URL(`/posts/${post.slug}`, Astro.site).href,
    ogType: "article",
    publishedDate: date,
  }}
  showSidebar={false}
>
  <article class="post-article">
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <span class="post-author">{author}</span>
        <span aria-hidden="true" class="meta-sep">·</span>
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>

      {
        (categories.length > 0 || tags.length > 0) && (
          <div class="post-taxonomies">
            {categories.map((cat) => (
              <a href={`/categories/${slugify(cat)}`} class="pill">{cat}</a>
            ))}
            {tags.map((tag) => (
              <a href={`/tags/${slugify(tag)}`} class="pill pill-tag">#{tag}</a>
            ))}
          </div>
        )
      }
    </header>

    <hr class="hairline post-divider" />

    <div class="article-body">
      {post.body}
    </div>
  </article>

  <nav class="post-back" aria-label="Back navigation">
    <a href="/">&larr; Back to all posts</a>
  </nav>
</BaseLayout>

<style>
  .post-article {
    max-width: 65ch;
    margin: 0 auto;
  }

  .post-header {
    margin-bottom: 1.5rem;
  }

  .post-title {
    margin-bottom: 0.5rem;
  }

  .post-meta {
    font-size: 0.95rem;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  .post-author {
    font-weight: 500;
    color: var(--color-fg);
  }

  .meta-sep {
    margin: 0 0.5rem;
    color: var(--color-border);
  }

  .post-taxonomies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .post-taxonomies .pill {
    text-decoration: none;
  }

  .post-taxonomies .pill-tag {
    background: transparent;
    border-color: transparent;
    padding: 0.2em 0.5em;
  }

  .post-divider {
    margin-bottom: 2rem;
  }

  .post-back {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    max-width: 65ch;
    margin-left: auto;
    margin-right: auto;
  }

  .post-back a {
    font-size: 0.95rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .post-back a:hover {
    color: var(--color-accent);
  }
</style>
