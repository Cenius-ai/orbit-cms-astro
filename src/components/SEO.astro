---
export interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogType?: "website" | "article";
  ogImage?: string;
  publishedDate?: Date;
}

const {
  title,
  description,
  canonicalURL,
  ogType = "website",
  ogImage,
  publishedDate,
} = Astro.props;

const siteTitle = "Orbit";
const fullTitle = title === "Orbit" ? siteTitle : `${title} — ${siteTitle}`;
const siteURL = Astro.site?.origin ?? "https://orbit-blog.dev";
const finalCanonical = canonicalURL ?? Astro.url.href;
const finalOgImage = ogImage ?? `${siteURL}/orbit-og-default.svg`;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={finalCanonical} />

<!-- Open Graph -->
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={finalCanonical} />
<meta property="og:image" content={finalOgImage} />
<meta property="og:site_name" content="Orbit" />
<meta property="og:locale" content="en_US" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={finalOgImage} />

{ publishedDate && <meta property="article:published_time" content={publishedDate.toISOString()} /> }
