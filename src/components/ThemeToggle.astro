<button
  class="theme-toggle"
  id="theme-toggle"
  aria-label="Toggle dark mode"
  type="button"
>
  <span class="light-icon" aria-hidden="true">☀</span>
  <span class="dark-icon" aria-hidden="true">☾</span>
</button>

<style>
  .dark-icon { display: none; }
  .dark .dark-icon { display: inline; }
  .dark .light-icon { display: none; }
</style>

<script>
  function applyTheme(theme: "light" | "dark") {
    document.documentElement.classList.toggle("dark", theme === "dark");
    try { localStorage.setItem("orbit-theme", theme); } catch {}
  }

  function getPref(): "light" | "dark" {
    try {
      const stored = localStorage.getItem("orbit-theme");
      if (stored === "dark" || stored === "light") return stored;
    } catch {}
    if (window.matchMedia("(prefers-color-scheme: dark)").matches) return "dark";
    return "light";
  }

  // Apply on load to prevent flash
  applyTheme(getPref());

  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const next = document.documentElement.classList.contains("dark") ? "light" : "dark";
    applyTheme(next);
  });
</script>
