---
export interface Props {
  title: string;
  slug: string;
  date: Date;
  excerpt: string;
  author: string;
  categories: string[];
  tags: string[];
}

const { title, slug, date, excerpt, author, categories, tags } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a href={`/posts/${slug}`} class="post-card">
  <div class="post-card-header">
    <h2>{title}</h2>
    <div class="meta">
      <span>{author}</span>
      <span aria-hidden="true">·</span>
      <time datetime={date.toISOString()}>{formattedDate}</time>
    </div>
  </div>
  <p class="excerpt">{excerpt}</p>

  {
    (categories.length > 0 || tags.length > 0) && (
      <div class="post-card-footer">
        {categories.map((cat) => (
          <span class="pill" data-stop-propagation>
            <a href={`/categories/${cat.toLowerCase().replace(/\s+/g, "-")}`}>{cat}</a>
          </span>
        ))}
        {tags.slice(0, 3).map((tag) => (
          <span class="pill pill-tag">
            <a href={`/tags/${tag.toLowerCase().replace(/\s+/g, "-")}`}>#{tag}</a>
          </span>
        ))}
      </div>
    )
  }
</a>

<style>
  .post-card-footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.75rem;
  }

  .post-card-footer .pill a {
    color: inherit;
    text-decoration: none;
  }

  .pill-tag {
    background: transparent;
    border-color: transparent;
    padding: 0.2em 0.5em;
  }

  .post-card-footer .pill:hover a {
    color: var(--color-accent);
  }

  /* Stop the parent <a> from navigating when clicking a pill */
  .post-card-footer .pill a {
    position: relative;
    z-index: 1;
  }
</style>
