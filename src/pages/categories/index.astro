---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts, buildTaxonomy } from "../../lib/utils";

const posts = await getPublishedPosts();
const categories = buildTaxonomy(posts, "categories");
---

<BaseLayout
  seo={{
    title: "Categories",
    description: "Browse all blog post categories on Orbit.",
    canonicalURL: new URL("/categories", Astro.site).href,
  }}
  showSidebar={false}
>
  <section class="taxonomy-page" aria-labelledby="categories-heading">
    <h1 id="categories-heading">Categories</h1>
    <p class="intro">Browse posts by topic.</p>

    {categories.length === 0 && (
      <p class="empty-state">No categories yet.</p>
    )}

    <div class="taxonomy-grid">
      {categories.map((cat) => (
        <a href={`/categories/${cat.slug}`} class="taxonomy-card">
          <span class="taxonomy-name">{cat.name}</span>
          <span class="taxonomy-count">{cat.count} post{cat.count !== 1 ? "s" : ""}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .taxonomy-page {
    max-width: 65ch;
    margin: 0 auto;
  }

  .taxonomy-page h1 {
    margin-bottom: 0.25rem;
  }

  .intro {
    color: var(--color-muted);
    margin-bottom: 2rem;
  }

  .taxonomy-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.75rem;
  }

  .taxonomy-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .taxonomy-card:hover {
    border-color: var(--color-accent-300);
    background: var(--color-surface);
    text-decoration: none;
  }

  .taxonomy-name {
    font-weight: 500;
    color: var(--color-fg);
  }

  .taxonomy-count {
    font-size: 0.85rem;
    color: var(--color-muted);
    font-variant-numeric: tabular-nums;
  }

  .empty-state {
    color: var(--color-muted);
    font-style: italic;
    padding: 2rem 0;
  }
</style>
