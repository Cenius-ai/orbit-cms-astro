---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getPublishedPosts, buildTaxonomy } from "../../lib/utils";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = buildTaxonomy(posts, "tags");
  return tags.map((tag) => ({
    params: { slug: tag.slug },
    props: { name: tag.name },
  }));
}

interface Props {
  name: string;
}

const { name } = Astro.props;
const slug = Astro.params.slug!;

const allPosts = await getPublishedPosts();
const matching = allPosts.filter((p) =>
  (p.data.tags ?? []).some(
    (t) => t.toLowerCase().replace(/\s+/g, "-") === slug,
  ),
);
---

<BaseLayout
  seo={{
    title: `#${name} — Tags`,
    description: `Browse all blog posts tagged "${name}" on Orbit.`,
    canonicalURL: new URL(`/tags/${slug}`, Astro.site).href,
  }}
  showSidebar={false}
>
  <section class="listing-page" aria-labelledby="listing-heading">
    <h1 id="listing-heading">#{name}</h1>
    <p class="intro">
      {matching.length} post{matching.length !== 1 ? "s" : ""} with this tag.
    </p>

    {matching.length === 0 && (
      <p class="empty-state">No posts with this tag yet.</p>
    )}

    {matching.map((post) => (
      <PostCard
        title={post.data.title}
        slug={post.slug}
        date={post.data.date}
        excerpt={post.data.excerpt}
        author={post.data.author}
        categories={post.data.categories}
        tags={post.data.tags}
      />
    ))}

    <nav class="back-nav">
      <a href="/tags">&larr; All tags</a>
    </nav>
  </section>
</BaseLayout>

<style>
  .listing-page {
    max-width: 65ch;
    margin: 0 auto;
  }

  .listing-page h1 {
    margin-bottom: 0.25rem;
  }

  .intro {
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .empty-state {
    color: var(--color-muted);
    font-style: italic;
    padding: 2rem 0;
  }

  .back-nav {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .back-nav a {
    font-size: 0.95rem;
    color: var(--color-muted);
    text-decoration: none;
  }

  .back-nav a:hover {
    color: var(--color-accent);
  }
</style>
